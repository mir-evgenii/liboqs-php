{
    "name": "mir-evgenii/liboqs-php",
    "description": "Post-quantum cryptography (ML-KEM, ML-DSA) for PHP via FFI bindings to liboqs",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-ffi": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Oqs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oqs\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}